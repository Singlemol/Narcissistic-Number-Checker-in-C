#include <stdio.h>

int main() {
    int n, originalNumber, remainder, result = 0;

    printf("Enter a 3-digit integer (100 to 999): ");
    scanf("%d", &n);

    // Validate if the input is a 3-digit number
    if (n < 100 || n > 999) {
        printf("Error: Please enter a number between 100 and 999.\n");
        return 1;
    }

    originalNumber = n;

    // Extract digits and calculate the sum of their cubes
    while (originalNumber != 0) {
        remainder = originalNumber % 10;   // Gets the last digit
        result += remainder * remainder * remainder; // Adds the cube of the digit
        originalNumber /= 10;              // Removes the last digit
    }

    // Check if the sum equals the original number
    if (result == n) {
        printf("%d is a Narcissistic number.\n", n);
    } else {
        printf("%d is NOT a Narcissistic number.\n", n);
    }

    return 0;
}
